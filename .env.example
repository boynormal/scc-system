# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/machine_maintenance"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-this-to-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── File Storage (Cloudflare R2 or AWS S3) ────────────────────────────────────
STORAGE_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="machine-maintenance"
STORAGE_PUBLIC_URL="https://pub-<hash>.r2.dev"

# ─── Email (Resend.com) ────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Machine Maintenance System"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── GPS Tracker (thaigpstracker.co.th) ────────────────────────────────────────
GPS_API_URL="https://gps.thaigpstracker.co.th/api2/map/getRealTimeData"
GPS_API_AUTH="Basic <base64-encoded-credentials>"
GPS_ASSET_ID="2013"
